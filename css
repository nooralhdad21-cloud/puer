/* تحسينات إضافية لتجربة الموبايل */
input:focus {
    transform: translateY(-1px);
}

.vendor-card {
    transition: all 0.2s ease;
}

.vendor-card:active {
    background-color: #f1f5f9;
}

/* حركة الأنيميشن عند المطابقة */
.matched-anim {
    animation: successPulse 0.5s ease;
}

@keyframes successPulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); background-color: #dcfce7; }
    100% { transform: scale(1); }
}

/* Scrollbar مخفي لإعطاء مظهر تطبيق */
::-webkit-scrollbar {
    width: 4px;
}
::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 10px;
}
